{\n  \"name\": \"inventariaje-app\",\n  \"version\": \"1.0.0\",\n  \"description\": \"App de gestión de inventario con scanner de códigos de barras, sincronización con Google Sheets y reportes mensuales\",\n  \"main\": \"node_modules/expo/AppEntry.js\",\n  \"scripts\": {\n    \"start\": \"expo start\",\n    \"android\": \"expo start --android\",\n    \"ios\": \"expo start --ios\",\n    \"web\": \"expo start --web\",\n    \"eject\": \"expo eject\",\n    \"build:android\": \"eas build --platform android --local\",\n    \"build:ios\": \"eas build --platform ios --local\",\n    \"build:prod:android\": \"eas build --platform android --local --profile release\"\n  },\n  \"dependencies\": {\n    \"expo\": \"^50.0.0\",\n    \"expo-barcode-scanner\": \"^13.0.1\",\n    \"expo-linear-gradient\": \"^13.0.0\",\n    \"expo-status-bar\": \"^1.11.1\",\n    \"expo-vector-icons\": \"^14.0.0\",\n    \"react\": \"18.2.0\",\n    \"react-native\": \"0.73.4\",\n    \"@react-navigation/native\": \"^6.1.17\",\n    \"@react-navigation/bottom-tabs\": \"^6.5.17\",\n    \"@react-navigation/native-stack\": \"^6.9.25\",\n    \"react-native-screens\": \"^3.27.0\",\n    \"react-native-safe-area-context\": \"^4.8.2\",\n    \"@react-native-async-storage/async-storage\": \"^1.21.0\",\n    \"axios\": \"^1.6.2\"\n  },\n  \"devDependencies\": {\n    \"@babel/core\": \"^7.23.6\",\n    \"@babel/preset-react\": \"^7.23.3\",\n    \"@types/react\": \"~18.2.0\",\n    \"@types/react-native\": \"~0.73.0\",\n    \"typescript\": \"^5.3.3\"\n  },\n  \"private\": true,\n  \"engines\": {\n    \"node\": \">=18.0.0\",\n    \"npm\": \">=9.0.0\"\n  },\n  \"keywords\": [\n    \"inventario\",\n    \"barcode\",\n    \"scanner\",\n    \"google-sheets\",\n    \"react-native\",\n    \"expo\"\n  ],\n  \"author\": \"Tu Nombre\",\n  \"license\": \"MIT\",\n  \"homepage\": \".\"\n}\n