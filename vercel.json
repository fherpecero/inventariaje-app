{
  "buildCommand": "npm install",
  "outputDirectory": "./",
  "env": {
    "GOOGLE_CREDENTIALS": "@GOOGLE_CREDENTIALS",
    "SHEET_ID": "@SHEET_ID"
  },
  "functions": {
    "api.js": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api.js"
    }
  ]
}